{
  "mcpServers": {
    "youtrack": {
      "type": "http",
      "url": "https://youtrack.jetbrains.com/mcp",
      "headers": {
        "Authorization": "Bearer ${YOUTRACK_MCP_TOKEN}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_TOKEN}"
      }
    }
  }
}
